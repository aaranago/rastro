# Copy this file to `.env` for local development. Keep real secrets out of this template.

# Expo mobile app
# API origin used by Expo; devices/dev clients need a reachable LAN or HTTPS URL.
EXPO_PUBLIC_API_BASE_URL="http://10.0.2.2:3000"
# Public EAS project id used for development-client and push-token flows.
EXPO_PUBLIC_EAS_PROJECT_ID="ba6b6ed0-beb7-429a-9410-19dc361607f3"
# Native foreground location permission message.
EXPO_LOCATION_WHEN_IN_USE_PERMISSION="Rastro usa tu ubicacion mientras usas la app para actualizar tu area de alertas y mostrar reportes cercanos."
# Native map provider keys. Leave blank for local work that does not render native maps.
# Android dev-client/store builds require a Google Maps Android SDK key.
EXPO_ANDROID_GOOGLE_MAPS_API_KEY=""
# Optional Google Maps iOS SDK key if you enable Google Maps on iOS; Apple Maps works without this.
EXPO_IOS_GOOGLE_MAPS_API_KEY=""

# Database
# Local Postgres URL; production should use the deployment database URL.
POSTGRES_URL="postgres://postgres:postgres@localhost:5432/rastro"

# Report media storage
# S3/MinIO-compatible private bucket used for backend-owned upload sessions.
RASTRO_STORAGE_BUCKET="rastro-media"
RASTRO_STORAGE_REGION="us-east-1"
# Backend/internal endpoint for HEAD/DELETE operations. Leave blank for AWS S3.
RASTRO_STORAGE_INTERNAL_ENDPOINT="http://localhost:9000"
# Public endpoint used when presigning upload instructions for mobile. Leave blank for AWS S3.
RASTRO_STORAGE_PRESIGN_ENDPOINT="http://10.0.2.2:9000"
RASTRO_STORAGE_FORCE_PATH_STYLE="true"
RASTRO_STORAGE_TLS="false"
# Optional CDN or image delivery origin for read URLs; bucket remains private.
RASTRO_STORAGE_DELIVERY_BASE_URL=""
RASTRO_STORAGE_PRESIGN_EXPIRES_SECONDS="300"
RASTRO_STORAGE_MAX_IMAGE_BYTES="10485760"
RASTRO_STORAGE_ALLOWED_MIME_TYPES="image/jpeg,image/png,image/webp,image/heic,image/heif"
# Dev-only placeholders. Replace in local .env and production secret manager.
RASTRO_STORAGE_ACCESS_KEY_ID="dev-minio-access-key"
RASTRO_STORAGE_SECRET_ACCESS_KEY="dev-minio-secret-key"
# Set to 1 only for explicit storage integration tests against a disposable bucket.
RASTRO_STORAGE_INTEGRATION="0"
# Bearer token required by the server-side report media cleanup job route.
RASTRO_JOB_SECRET="dev-only-change-me"

# Next.js and Better Auth
# Public web origin used by Better Auth callbacks.
BETTER_AUTH_URL="http://localhost:3000"
# Dev-only sample; generate a high-entropy value for shared or production envs.
AUTH_SECRET="dev-only-change-me-32-bytes-minimum"
# Keep false for Bolivia v1 unless auth policy changes.
AUTH_REQUIRE_EMAIL_VERIFICATION="false"
# Comma-separated admin emails for the moderation UI.
RASTRO_ADMIN_EMAILS="admin@example.com"

# Optional OAuth providers. Leave blank until provider apps are configured.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""
AUTH_APPLE_CLIENT_ID=""
AUTH_APPLE_CLIENT_SECRET=""
AUTH_APPLE_APP_BUNDLE_IDENTIFIER=""

# Vercel-provided values. Leave URL fields blank for local runs.
VERCEL_ENV="development"
VERCEL_URL=""
VERCEL_PROJECT_PRODUCTION_URL=""

# Local runtime and tooling values read by validation or URL fallbacks.
NODE_ENV="development"
PORT="3000"
CI=""
npm_lifecycle_event=""
