# Dokploy production checklist for the Next.js web/API Docker app.
#
# Set every non-optional value below in BOTH Dokploy sections:
# - Environment variables
# - Build arguments
#
# In the Dokploy UI, paste raw values without shell quotes. Replace every
# YOUR_* and CHANGE_ME value before deploying.

NODE_ENV=production
PORT=3000

# Web/API origin and database
POSTGRES_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/rastro
BETTER_AUTH_URL=https://app.rastro.dpdns.org

# Production auth secrets
AUTH_SECRET=CHANGE_ME_AUTH_SECRET_32_PLUS_CHARS
AUTH_REQUIRE_EMAIL_VERIFICATION=false

# Admin access
RASTRO_ADMIN_EMAILS=admin@example.com

# Required production install URLs used by /descargar and env validation.
# Use /descargar as a temporary fallback until store URLs exist.
RASTRO_ANDROID_INSTALL_URL=https://app.rastro.dpdns.org/descargar
RASTRO_IOS_INSTALL_URL=https://app.rastro.dpdns.org/descargar

# Required production email sender/webhook for auth email flows.
RASTRO_AUTH_EMAIL_FROM=no-reply@app.rastro.dpdns.org
RASTRO_AUTH_EMAIL_WEBHOOK_URL=https://YOUR_EMAIL_WEBHOOK_URL
RASTRO_AUTH_EMAIL_WEBHOOK_SECRET=CHANGE_ME_EMAIL_WEBHOOK_SECRET_32_PLUS_CHARS

# Scheduled jobs and sponsor token signing.
RASTRO_JOB_SECRET=CHANGE_ME_JOB_SECRET_32_PLUS_CHARS
RASTRO_SPONSOR_DELIVERY_TOKEN_SECRET=CHANGE_ME_SPONSOR_SECRET_32_PLUS_CHARS

# MinIO/S3-compatible report media storage.
RASTRO_STORAGE_BUCKET=rastro-media
RASTRO_STORAGE_REGION=us-east-1
RASTRO_STORAGE_INTERNAL_ENDPOINT=http://rastro-minio:9000
RASTRO_STORAGE_PRESIGN_ENDPOINT=https://uploads.rastro.dpdns.org
RASTRO_STORAGE_FORCE_PATH_STYLE=true
RASTRO_STORAGE_TLS=true
RASTRO_STORAGE_DELIVERY_BASE_URL=
RASTRO_STORAGE_PRESIGN_EXPIRES_SECONDS=300
RASTRO_STORAGE_MAX_IMAGE_BYTES=10485760
RASTRO_STORAGE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/heic,image/heif
RASTRO_STORAGE_ACCESS_KEY_ID=YOUR_MINIO_ACCESS_KEY
RASTRO_STORAGE_SECRET_ACCESS_KEY=CHANGE_ME_STORAGE_SECRET_32_PLUS_CHARS

# Optional OAuth providers. Set only after provider dashboards are configured.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=
AUTH_APPLE_CLIENT_ID=
AUTH_APPLE_CLIENT_SECRET=
AUTH_APPLE_APP_BUNDLE_IDENTIFIER=bo.rastro.app
AUTH_REDIRECT_PROXY_URL=

# Leave Vercel values blank on Dokploy.
VERCEL_ENV=
VERCEL_URL=
VERCEL_PROJECT_PRODUCTION_URL=
