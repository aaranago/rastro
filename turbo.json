{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".cache/tsbuildinfo.json", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^dev"],
      "cache": false,
      "persistent": false
    },
    "format": {
      "outputs": [".cache/.prettiercache"],
      "outputLogs": "new-only"
    },
    "generate": {
      "cache": false,
      "interactive": true
    },
    "lint": {
      "dependsOn": ["^topo", "^build"],
      "outputs": [".cache/.eslintcache"]
    },
    "migrate": {
      "cache": false,
      "interactive": true
    },
    "test": {
      "dependsOn": ["^topo"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^topo", "^build"],
      "outputs": [".cache/tsbuildinfo.json"]
    },
    "clean": {
      "cache": false
    },
    "//#clean": {
      "cache": false
    },
    "push": {
      "cache": false,
      "interactive": true
    },
    "studio": {
      "cache": false,
      "persistent": true
    },
    "ui-add": {
      "cache": false,
      "interactive": true
    }
  },
  "globalEnv": [
    "POSTGRES_URL",
    "RASTRO_DB_INTEGRATION",
    "RASTRO_STORAGE_ACCESS_KEY_ID",
    "RASTRO_STORAGE_ALLOWED_MIME_TYPES",
    "RASTRO_STORAGE_BUCKET",
    "RASTRO_STORAGE_DELIVERY_BASE_URL",
    "RASTRO_STORAGE_FORCE_PATH_STYLE",
    "RASTRO_STORAGE_INTEGRATION",
    "RASTRO_STORAGE_INTERNAL_ENDPOINT",
    "RASTRO_JOB_SECRET",
    "RASTRO_STORAGE_MAX_IMAGE_BYTES",
    "RASTRO_STORAGE_PRESIGN_ENDPOINT",
    "RASTRO_STORAGE_PRESIGN_EXPIRES_SECONDS",
    "RASTRO_STORAGE_REGION",
    "RASTRO_STORAGE_SECRET_ACCESS_KEY",
    "RASTRO_STORAGE_TLS",
    "AUTH_APPLE_APP_BUNDLE_IDENTIFIER",
    "AUTH_APPLE_CLIENT_ID",
    "AUTH_APPLE_CLIENT_SECRET",
    "AUTH_FACEBOOK_ID",
    "AUTH_FACEBOOK_SECRET",
    "AUTH_GOOGLE_ID",
    "AUTH_GOOGLE_SECRET",
    "AUTH_REQUIRE_EMAIL_VERIFICATION",
    "AUTH_REDIRECT_PROXY_URL",
    "AUTH_SECRET",
    "BETTER_AUTH_URL",
    "PORT"
  ],
  "globalPassThroughEnv": [
    "NODE_ENV",
    "CI",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "npm_lifecycle_event"
  ]
}
